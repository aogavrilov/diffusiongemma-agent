OPENAI_BASE_URL=http://127.0.0.1:4100/v1
OPENAI_API_KEY=dummy
OPENAI_MODEL=diffusiongemma-local

OPENHANDS_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/openhands.dg.toml
OPENHANDS_ENV=/root/diffusiongemma-agent/configs/client_profiles/openhands.env
QWEN_CODE_MCP_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/qwen-code.mcp.json
QWEN_CODE_COMMAND=scripts/dg_agent.sh qwen-code -- --repo /repo --dry-run
AUTOGEN_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/autogen.dg.json
AUTOGEN_COMMAND=scripts/dg_agent.sh autogen -- --repo /repo --dry-run
AUTOGEN_MODEL=diffusiongemma-local
SMOLAGENTS_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/smolagents.dg.json
SMOLAGENTS_COMMAND=scripts/dg_agent.sh smolagents -- --repo /repo --dry-run
SMOLAGENTS_MODEL=diffusiongemma-local
LANGGRAPH_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/langgraph.dg.json
LANGGRAPH_COMMAND=scripts/dg_agent.sh langgraph -- --repo /repo --dry-run
LANGGRAPH_MODEL=diffusiongemma-local
CREWAI_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/crewai.dg.json
CREWAI_COMMAND=scripts/dg_agent.sh crewai -- --repo /repo --dry-run
CREWAI_MODEL=openai/diffusiongemma-local
OPEN_INTERPRETER_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/open-interpreter.dg.json
OPEN_INTERPRETER_COMMAND=scripts/dg_agent.sh open-interpreter -- --repo /repo --dry-run
OPEN_INTERPRETER_MODEL=openai/diffusiongemma-local
LLAMAINDEX_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/llamaindex.dg.json
LLAMAINDEX_COMMAND=scripts/dg_agent.sh llamaindex -- --repo /repo --dry-run
LLAMAINDEX_MODEL=diffusiongemma-local
HAYSTACK_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/haystack.dg.json
HAYSTACK_COMMAND=scripts/dg_agent.sh haystack -- --repo /repo --dry-run
HAYSTACK_MODEL=diffusiongemma-local
LLM_MODEL=litellm_proxy/diffusiongemma-local
LLM_BASE_URL=http://127.0.0.1:4100
LLM_API_KEY=dummy
LLM_DROP_PARAMS=true
LLM_DISABLE_VISION=true
LLM_CACHING_PROMPT=false

SWE_AGENT_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/swe-agent.dg.yaml
MINI_SWE_AGENT_CONFIG=/root/diffusiongemma-agent/configs/client_profiles/mini-swe-agent.dg.yaml
LITELLM_MODEL_REGISTRY_PATH=/root/diffusiongemma-agent/configs/client_profiles/litellm-local-model-registry.json
SWE_AGENT_MODEL=openai/diffusiongemma-local
SWE_AGENT_API_BASE=http://127.0.0.1:4100/v1
