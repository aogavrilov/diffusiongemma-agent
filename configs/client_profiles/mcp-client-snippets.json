{
  "name": "DiffusionGemma local MCP client snippets",
  "server_name": "diffusiongemma-local-agent",
  "server_command": "/root/diffusiongemma-agent/scripts/run_mcp_server.sh",
  "transport": "stdio",
  "recommended_bundle": {
    "name": "dg-repomix-serena",
    "servers": [
      "diffusiongemma-local-agent",
      "repomix",
      "serena"
    ],
    "description": "DG workflow tools plus upstream Repomix repository packing and upstream Serena semantic/LSP tools."
  },
  "optional_servers": {
    "repomix": {
      "description": "Native upstream Repomix MCP server for repository packing.",
      "command": "/root/diffusiongemma-agent/scripts/run_repomix_mcp.sh",
      "args": [],
      "env": {}
    },
    "serena": {
      "description": "Native upstream Serena MCP server for semantic/LSP code tools.",
      "command": "/root/diffusiongemma-agent/scripts/run_serena_mcp.sh",
      "args": [],
      "env": {}
    }
  },
  "clients": {
    "claude_code": {
      "target": ".mcp.json",
      "config_file": "configs/client_profiles/claude-code.mcp.json",
      "format": "mcpServers",
      "snippet": {
        "mcpServers": {
          "diffusiongemma-local-agent": {
            "command": "/root/diffusiongemma-agent/scripts/run_mcp_server.sh",
            "args": [],
            "env": {}
          },
          "repomix": {
            "command": "/root/diffusiongemma-agent/scripts/run_repomix_mcp.sh",
            "args": [],
            "env": {}
          },
          "serena": {
            "command": "/root/diffusiongemma-agent/scripts/run_serena_mcp.sh",
            "args": [],
            "env": {}
          }
        }
      }
    },
    "claude_desktop": {
      "target": "claude_desktop_config.json",
      "config_file": "configs/client_profiles/claude-desktop-mcp.json",
      "format": "mcpServers",
      "snippet": {
