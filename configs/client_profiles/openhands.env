# OpenHands local DiffusionGemma profile.
# Source this before starting OpenHands if you prefer env configuration.

LLM_MODEL=litellm_proxy/diffusiongemma-local
LLM_BASE_URL=http://127.0.0.1:4100
LLM_API_KEY=dummy
LLM_DROP_PARAMS=true
LLM_DISABLE_VISION=true
LLM_CACHING_PROMPT=false
LLM_NUM_RETRIES=2
LLM_RETRY_MIN_WAIT=1
LLM_RETRY_MAX_WAIT=10
LLM_RETRY_MULTIPLIER=2
OPENHANDS_SUPPRESS_BANNER=1
PYTHONWARNINGS=ignore
